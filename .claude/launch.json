{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite dev server)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "../trading-strategy-ui",
      "port": 5173
    },
    {
      "name": "Backend (FastAPI + uvicorn)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "cwd": "../trading-strategy-backend",
      "port": 8000
    },
    {
      "name": "Full Stack (Docker Compose)",
      "runtimeExecutable": "docker-compose",
      "runtimeArgs": ["up", "--build"],
      "cwd": ".",
      "port": 5173
    }
  ]
}
