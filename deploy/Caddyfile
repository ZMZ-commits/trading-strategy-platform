# Caddy reverse proxy with automatic HTTPS via Let's Encrypt.
# DNS records for these subdomains must point to the Oracle VM's public IP.

api.zemingzhang.com {
    reverse_proxy backend-prod:8000
    encode gzip
}

api-stg.zemingzhang.com {
    reverse_proxy backend-stg:8000
    encode gzip
}

api-dev.zemingzhang.com {
    reverse_proxy backend-dev:8000
    encode gzip
}
