# Caddy reverse proxy with automatic HTTPS via Let's Encrypt.
# DNS records for these subdomains must point to the Hetzner VM's public IP.

# ── Backends (API) ──────────────────────────────────────────────
api.zemingzhang.com {
    reverse_proxy backend-prod:8000
    encode gzip
}

api-stg.zemingzhang.com {
    reverse_proxy backend-stg:8000
    encode gzip
}

api-dev.zemingzhang.com {
    reverse_proxy backend-dev:8000
    encode gzip
}

# ── Frontends (React UI) ────────────────────────────────────────
# The UI is served by Cloudflare Pages, not this VM. The trading*.zemingzhang.com
# domains point at Cloudflare; Caddy here only proxies the APIs above.

# ── Optional: JupyterLab authoring (DISABLED by default) ─────────
# JupyterLab is arbitrary code execution. By default it is NOT exposed here —
# reach it via an SSH tunnel (see deploy/docker-compose.yml). Only enable public
# access AFTER (1) setting JUPYTER_TOKEN in deploy/.env and (2) creating a DNS
# record  lab.zemingzhang.com -> VM IP. Then uncomment:
#
# lab.zemingzhang.com {
#     reverse_proxy jupyterlab:8888
#     encode gzip
# }
